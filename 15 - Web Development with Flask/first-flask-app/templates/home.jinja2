{% extends 'base.jinja2' %}

{% block content %}
<h1>Welcome to the Blogs!</h1>
<h2>Posts</h2>
<ul>
  {%for post_id, post in posts.items():%}
  <li>
    <a href="{{url_for("get_post_by_id", post_id=post_id)}}">{{post["title"]}} </a>
  </li>
  {% endfor %}
</ul>

<a href="{{url_for("create")}}">Crete a New Post</a>
{% endblock %}
